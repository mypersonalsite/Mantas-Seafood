<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mantas Seafood</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f4f4;
            text-align: center;
        }

        .top-image {
            width: 100%;
            display: block;
        }

        header {
            background: #002b55;
            color: white;
            padding: 40px 20px;
            border-bottom: 4px solid #d4af37;
        }

        h1 {
            margin: 0;
            font-size: 38px;
            letter-spacing: 1px;
        }

        .subtitle {
            font-size: 18px;
            margin-top: 10px;
            color: #d4af37;
        }

        .container {
            margin-top: 40px;
            padding: 0 20px;
        }

        .btn {
            display: block;
            width: 100%;
            max-width: 340px;
            margin: 15px auto;
            padding: 16px;
            background: #003d80;
            color: white;
            text-decoration: none;
            font-size: 20px;
            border-radius: 12px;
            border: 2px solid #d4af37;
            transition: 0.2s;
        }

        .btn:hover {
            background: #002b55;
            transform: scale(1.03);
        }

        footer {
            margin-top: 60px;
            padding: 20px;
            color: #555;
            font-size: 14px;
        }

        /* Mobile Optimization */
        @media (max-width: 480px) {
            h1 { font-size: 30px; }
            .subtitle { font-size: 16px; }
            .btn { font-size: 18px; padding: 14px; }
        }
    </style>
</head>

<body>

    <img src="images/mantas.png" alt="Mantas Seafood" class="top-image">

    <header>
        <h1>Mantas Seafood</h1>
        <div class="subtitle">Fresh • Local • Authentic</div>
    </header>

    <div class="container">

        <!-- Google Maps -->
        <a class="btn"
           href="https://www.google.com/maps/place/Mandas/"
           target="_blank">
            📍 Βρες μας στο Google Maps
        </a>

        <!-- Google Review -->
        <a class="btn"
           href="https://www.google.com/maps/place/Mandas/"
           target="_blank">
            ⭐ Άφησε Κριτική
        </a>

        <!-- Menu PDF -->
        <a class="btn" href="menu.pdf" target="_blank">
            📖 Δες το Μενού (PDF)
        </a>

        <!-- Click to Call -->
        <a class="btn" href="tel:+3069XXXXXXXX">
            📞 Κάλεσέ μας
        </a>

        <!-- WhatsApp -->
